{
  "name": "postai-cloudflare",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:api": "wrangler dev -c services/api/wrangler.toml --ip 0.0.0.0",
    "dev:finance": "wrangler dev -c services/finance/wrangler.toml --ip 0.0.0.0",
    "dev:ops": "wrangler dev -c services/ops/wrangler.toml --ip 0.0.0.0",
    "deploy:api": "wrangler deploy -c services/api/wrangler.toml",
    "deploy:finance": "wrangler deploy -c services/finance/wrangler.toml",
    "deploy:ops": "wrangler deploy -c services/ops/wrangler.toml"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
